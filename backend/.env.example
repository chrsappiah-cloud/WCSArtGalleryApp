APP_NAME=World Class Scholars Art Gallery API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./wcs_gallery.db
MEDIA_ROOT=./media
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1.5
# Optional: public origin for /media/... links (tunnel, deployed API, or Mac LAN IP for device testing).
PUBLIC_BASE_URL=
# JSON array (required by pydantic-settings for list fields in .env)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:8000"]
